<% if f.object.multiple? key %>
  <%= f.input :description, as: :multi_value, input_html: { rows: '7', type: 'textarea'}, required: f.object.required?(key) %>
<% elsif f.object.respond_to?(:rich_text?) && f.object.rich_text?(key) %>
  <div class="form-group">
    <%= f.label :description, "Description", class: "form-control-label" %>
    <%= f.input_field :description, as: :hidden %>
    <trix-editor input="<%= ActiveModel::Naming.param_key(@change_set.resource) %>_description"></trix-editor>
  </div>
<% else %>
  <%= f.input :description, as: :text, input_html: { rows: '7' }, required: f.object.required?(key) %>
<% end %>
